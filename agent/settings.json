{
  "lastChangelogVersion": "0.75.5",
  "packages": [
    "npm:lsp-pi",
    "npm:@ogulcancelik/pi-minimal-footer",
    "npm:pi-schedule-prompt",
    "npm:@sherif-fanous/pi-rtk",
    "npm:pi-rtk-optimizer@0.7.1",
    "npm:pi-updater",
    "npm:@mjakl/pi-subagent@1.4.1",
    "npm:pi-model-aware-compaction",
    {
      "source": "git:github.com/tmustier/pi-extensions",
      "extensions": [
        "tab-status/tab-status.ts",
        "session-recap/index.ts"
      ],
      "skills": []
    },
    "npm:@siddr/pi-review",
    "npm:@narumitw/pi-goal",
    "npm:pi-codex-fast",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:@sting8k/pi-vcc"
  ],
  "defaultThinkingLevel": "medium",
  "enabledModels": [
    "openai-codex/gpt-5.5",
    "openai-codex/gpt-5.4-mini",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.3-codex"
  ],
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "treeFilterMode": "no-tools",
  "steeringMode": "all",
  "terminal": {
    "showTerminalProgress": true
  },
  "compaction": {
    "enabled": true,
    "reserveTokens": 9000,
    "keepRecentTokens": 20000
  },
  "lsp": {
    "hookMode": "edit_write"
  },
  "lcm": {
    "enabled": false,
    "leafChunkTokens": 4000,
    "condensationThreshold": 6,
    "maxDepth": 5,
    "maxSummaryTokens": 8000,
    "minMessagesForCompaction": 10,
    "leafPassConcurrency": 8,
    "debugMode": true,
    "compactionModels": [
      {
        "provider": "openai-codex",
        "id": "gpt-5.4-mini"
      }
    ]
  }
}