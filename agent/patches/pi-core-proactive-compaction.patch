diff --git a/packages/coding-agent/test/agent-session-proactive-compaction.test.ts b/packages/coding-agent/test/agent-session-proactive-compaction.test.ts
new file mode 100644
index 0000000..8b9cf5f
--- /dev/null
+++ b/packages/coding-agent/test/agent-session-proactive-compaction.test.ts
@@ -0,0 +1,126 @@
+import { existsSync, mkdirSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join } from "node:path";
+import { Agent } from "@earendil-works/pi-agent-core";
+import { createAssistantMessageEventStream, fauxAssistantMessage } from "@earendil-works/pi-ai";
+import { getModel } from "@earendil-works/pi-ai/compat";
+import { Type } from "typebox";
+import { afterEach, beforeEach, describe, expect, it } from "vitest";
+import { AgentSession } from "../src/core/agent-session.ts";
+import { AuthStorage } from "../src/core/auth-storage.ts";
+import { ModelRegistry } from "../src/core/model-registry.ts";
+import { SessionManager } from "../src/core/session-manager.ts";
+import { SettingsManager } from "../src/core/settings-manager.ts";
+import { createTestExtensionsResult, createTestResourceLoader } from "./utilities.ts";
+
+function usage(totalTokens: number) {
+	return {
+		input: totalTokens,
+		output: 0,
+		cacheRead: 0,
+		cacheWrite: 0,
+		totalTokens,
+		cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0, total: 0 },
+	};
+}
+
+describe("AgentSession proactive compaction", () => {
+	let session: AgentSession;
+	let tempDir: string;
+
+	beforeEach(() => {
+		tempDir = join(tmpdir(), `pi-proactive-compaction-${Date.now()}-${Math.random().toString(36).slice(2)}`);
+		mkdirSync(tempDir, { recursive: true });
+	});
+
+	afterEach(() => {
+		session?.dispose();
+		if (tempDir && existsSync(tempDir)) rmSync(tempDir, { recursive: true, force: true });
+	});
+
+	it("compacts before the next provider request after a tool result crosses the threshold", async () => {
+		const model = getModel("anthropic", "claude-sonnet-4-5")!;
+		model.contextWindow = 1_000;
+		const providerCalls: Array<{ messages: unknown[] }> = [];
+		let call = 0;
+
+		const agent = new Agent({
+			initialState: { model, systemPrompt: "test", tools: [] },
+		});
+		agent.streamFn = (streamModel, context) => {
+			providerCalls.push({ messages: context.messages });
+			const stream = createAssistantMessageEventStream();
+			const message = {
+				...fauxAssistantMessage(call++ === 0 ? "" : "done"),
+				api: streamModel.api,
+				provider: streamModel.provider,
+				model: streamModel.id,
+				content:
+					call === 1
+						? [{ type: "toolCall", id: "probe-1", name: "probe", arguments: {} }]
+						: [{ type: "text", text: "done" }],
+				stopReason: call === 1 ? "toolUse" : "stop",
+				usage: usage(call === 1 ? 800 : 20),
+			};
+			queueMicrotask(() => {
+				stream.push({ type: "done", reason: message.stopReason, message });
+				stream.end();
+			});
+			return stream;
+		};
+
+		const extensionsResult = await createTestExtensionsResult([
+			(pi) => {
+				pi.on("session_before_compact", async (event) => ({
+					compaction: {
+						summary: "compacted",
+						firstKeptEntryId: event.preparation.firstKeptEntryId,
+						tokensBefore: event.preparation.tokensBefore,
+					},
+				}));
+			},
+		]);
+		const sessionManager = SessionManager.inMemory();
+		const settingsManager = SettingsManager.create(tempDir, tempDir);
+		settingsManager.applyOverrides({ compaction: { reserveTokens: 100, keepRecentTokens: 1 } });
+		const authStorage = AuthStorage.create(join(tempDir, "auth.json"));
+		authStorage.setRuntimeApiKey(model.provider, "test-key");
+		const modelRegistry = ModelRegistry.create(authStorage, tempDir);
+		const tool = {
+			name: "probe",
+			label: "Probe",
+			description: "Returns a large result",
+			parameters: Type.Object({}),
+			execute: async () => ({ content: [{ type: "text", text: "x".repeat(1_000) }], details: {} }),
+		};
+
+		session = new AgentSession({
+			agent,
+			sessionManager,
+			settingsManager,
+			cwd: tempDir,
+			modelRegistry,
+			resourceLoader: createTestResourceLoader({ extensionsResult }),
+			customTools: [tool],
+			initialActiveToolNames: ["probe"],
+		});
+		await session.bindExtensions({});
+		sessionManager.appendMessage({ role: "user", content: [{ type: "text", text: "Earlier task" }], timestamp: Date.now() - 2_000 });
+		sessionManager.appendMessage({
+			...fauxAssistantMessage("Earlier answer"),
+			api: model.api,
+			provider: model.provider,
+			model: model.id,
+			usage: usage(100),
+			timestamp: Date.now() - 1_000,
+		});
+		agent.state.messages = sessionManager.buildSessionContext().messages;
+
+		await session.prompt("Use probe once");
+		await agent.waitForIdle();
+
+		expect(providerCalls).toHaveLength(2);
+		expect(sessionManager.getEntries().filter((entry) => entry.type === "compaction")).toHaveLength(1);
+		expect(providerCalls[1]!.messages.some((message: any) => JSON.stringify(message).includes("Earlier task"))).toBe(false);
+	});
+});
