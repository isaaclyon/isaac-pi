# Pi local secrets/state
auth.json
agent/auth.json
memory/
agent/memory/
agent/sessions/
agent/logs/
agent/lcm/
agent/update-cache.json
agent/run-history.jsonl
agent/pi-codex-conversion.json
agent/state/usage-analytics/
exa-usage.json
agent/backups/
agent.backup.*/
automations/

# Installed package clones/caches; settings.json is the source of truth
agent/git/**
!agent/git/
!agent/git/.gitignore
agent/npm/

# Roadmap Board shared config vs local state
.pi/*
!.pi/roadmap/
.pi/roadmap/roadmap.sqlite*
!.pi/roadmap/prompts.json
# Extension server-lifecycle state (transient; per-machine)
.pi/roadmap/.server.json
.pi/roadmap/.server.lock

# SQLite WAL/SHM sidecars (transient; reconstructed on open)
*.sqlite-shm
*.sqlite-wal

# Scratch/temp artifacts
.tmp-lsp-py/

# Dependencies/build outputs
node_modules/
*.log
.DS_Store
roadmap-board/dist/
